.member-selector {
  background: #fff;
  padding: 20rpx 24rpx 16rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.02);
}

.selector-scroll {
  display: flex;
  white-space: nowrap;
  padding-bottom: 8rpx;
}

.selector-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 32rpx;
  padding: 8rpx 4rpx;
  opacity: 0.5;
  transition: all 0.25s ease;
  position: relative;
}

.selector-item.active {
  opacity: 1;
  transform: translateY(-2rpx);
}

.selector-item:active {
  opacity: 0.8;
  transform: scale(0.95);
}

.sel-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 10rpx;
  transition: all 0.25s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.sel-avatar.male {
  background: linear-gradient(135deg, #4a90d9, #357abd);
}

.sel-avatar.female {
  background: linear-gradient(135deg, #e96d8a, #d45a78);
}

.selector-item.active .sel-avatar {
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
  transform: scale(1.08);
}

/* 选中指示器小圆点 */
.selector-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 16rpx;
  height: 4rpx;
  background: #07C160;
  border-radius: 2rpx;
}

.sel-name {
  font-size: 22rpx;
  color: #666;
  font-weight: 500;
  transition: color 0.2s ease;
}

.selector-item.active .sel-name {
  color: #07C160;
  font-weight: 600;
}

.selector-hint {
  font-size: 22rpx;
  color: #ccc;
  display: block;
  margin-top: 8rpx;
  text-align: center;
}
