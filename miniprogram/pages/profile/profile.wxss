.page {
  padding-bottom: 60rpx;
  background: #F2F4F7;
  min-height: 100vh;
}

/* ================= 用户卡片 ================= */
.user-card {
  display: flex;
  align-items: center;
  padding: 44rpx 32rpx;
  margin: 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #fff 0%, #FAFFFC 100%);
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07C160, #05a350);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 28rpx;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(7, 193, 96, 0.25);
}

.avatar-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: 700;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-id-label {
  font-size: 24rpx;
  color: #aaa;
  display: block;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.user-id-value {
  font-size: 28rpx;
  color: #1A1A1A;
  word-break: break-all;
  font-weight: 500;
  font-family: 'Courier New', monospace;
}

/* ================= 菜单列表 ================= */
.menu-list {
  margin: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #F5F5F5;
  transition: all 0.15s ease;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: #F8F9FB;
}

.menu-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.menu-icon-text {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

.icon-report { background: linear-gradient(135deg, #4a90d9, #357abd); }
.icon-member { background: linear-gradient(135deg, #e96d8a, #d45a78); }
.icon-group { background: linear-gradient(135deg, #07C160, #05a350); }

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #1A1A1A;
  font-weight: 500;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ddd;
  font-weight: 300;
}

/* ================= 关于 ================= */
.about {
  text-align: center;
  padding: 48rpx 0 32rpx;
}

.about-text {
  display: block;
  font-size: 24rpx;
  color: #ccc;
  margin-bottom: 6rpx;
}

/* ================= 退出 ================= */
.logout-area {
  padding: 20rpx 24rpx;
}

.btn-logout {
  width: 100%;
  background: #fff;
  color: #F5222D;
  border: 1rpx solid rgba(245, 34, 45, 0.12);
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 26rpx;
  text-align: center;
  font-weight: 500;
  transition: all 0.2s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
}

.btn-logout:active {
  background: #FFF5F5;
  border-color: rgba(245, 34, 45, 0.2);
}
