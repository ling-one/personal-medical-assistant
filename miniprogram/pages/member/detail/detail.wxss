.page {
  padding-bottom: 60rpx;
  background: #F2F4F7;
}

/* ================= 个人信息卡片 ================= */
.profile-card {
  padding: 44rpx 32rpx 36rpx;
  margin: 20rpx;
  border-radius: 20rpx;
}

.avatar-area {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.avatar {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-right: 28rpx;
  flex-shrink: 0;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.12);
}

.avatar.male {
  background: linear-gradient(135deg, #4a90d9, #357abd);
}

.avatar.female {
  background: linear-gradient(135deg, #e96d8a, #d45a78);
}

.profile-info {
  flex: 1;
  min-width: 0;
}

.name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
  margin-bottom: 10rpx;
}

.basic-info {
  font-size: 26rpx;
  color: #888;
  display: block;
  line-height: 1.6;
}

/* 快捷操作 */
.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

.action-row .action-btn {
  flex: 1;
  background: #F8F9FB;
  border-radius: 14rpx;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #555;
  text-align: center;
  line-height: 1;
  font-weight: 500;
  border: 1rpx solid rgba(0,0,0,0.04);
  transition: all 0.2s ease;
}

.action-row .action-btn:active {
  background: #F0F2F5;
  transform: translateY(1rpx);
}

/* ================= 章节标题 ================= */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #07C160, #05a350);
  border-radius: 3rpx;
}

/* ================= 信息行 ================= */
.info-row {
  margin-bottom: 24rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag {
  background: #F0FFF4;
  color: #07C160;
  border-radius: 10rpx;
  padding: 10rpx 22rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: 1rpx solid rgba(7, 193, 96, 0.1);
}

.tag-warn { background: #FFF8F0; color: #FA8C16; border-color: rgba(250, 140, 22, 0.1); }
.tag-blue { background: #F0F7FF; color: #1890FF; border-color: rgba(24, 144, 255, 0.1); }
.tag-red  { background: #FFF5F5; color: #F5222D; border-color: rgba(245, 34, 45, 0.1); }
.tag-orange { background: #FFF8F0; color: #FA8C16; border-color: rgba(250, 140, 22, 0.1); }

/* ================= 底部操作 ================= */
.bottom-actions {
  padding: 20rpx 24rpx;
}

.btn-report {
  width: 100%;
  background: #fff;
  color: #07C160;
  border: 1rpx solid rgba(7, 193, 96, 0.2);
  border-radius: 16rpx;
  padding: 26rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
  transition: all 0.2s ease;
}

.btn-report:active {
  background: #F0FFF4;
  border-color: rgba(7, 193, 96, 0.35);
}

.btn-delete {
  width: 100%;
  background: #fff;
  color: #F5222D;
  border: 1rpx solid rgba(245, 34, 45, 0.15);
  border-radius: 16rpx;
  padding: 22rpx 0;
  font-size: 26rpx;
  text-align: center;
  font-weight: 500;
  transition: all 0.2s ease;
}

.btn-delete:active {
  background: #FFF5F5;
}
