<view class="page">
  <view class="card">
    <view class="form-group">
      <text class="form-label">家庭组名称</text>
      <input
        class="input-field"
        placeholder="例如：我家"
        value="{{groupName}}"
        bindinput="onInput"
        maxlength="20"
      />
    </view>
    <text class="form-tip">创建后将获得一个9位组号，家人可通过组号加入</text>
  </view>

  <view class="submit-area">
    <button class="btn-primary" bindtap="createGroup">创建家庭组</button>
  </view>
</view>
